algoritmo "TesteVetores"
var

    num : vetor[1..5] de Inteiro
    i : Inteiro
inicio

      
      Para i <- 1 ate 5 faca
         Escreva("Digite os numeros: ")
         Leia(num[i])
      FimPara
      
         EscrevaL()
         Escreval("OS NUMEROS DIGITADOS:")
      Para i <- 1 ate 5 faca
         EscrevaL(num[i])
      FimPara
fimalgoritmo